# Copy to .env in the project root and adjust.

# --- Ollama (local LLM) — must match a model you pulled: ollama pull <name>
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://127.0.0.1:11434
# Speed tuning (optional): shorter = faster responses
OLLAMA_NUM_PREDICT=700
OLLAMA_TIMEOUT_SEC=180
OLLAMA_TEMPERATURE=0.65

# --- Optional: Google Gemini (if set, used before Ollama for some calls)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
